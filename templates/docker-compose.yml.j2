# Generated by swiftdeploy init - DO NOT EDIT MANUALLY

networks:
  {{ network.name }}:
    driver: {{ network.driver_type }}

volumes:
  app_logs:
    driver: local

services:

  service:
    image: {{ services.image }}
    restart: {{ services.restart_policy }}
    environment:
      MODE: "{{ services.mode }}"
      APP_VERSION: "{{ services.version }}"
      APP_PORT: "{{ services.port }}"
    networks:
      - {{ network.name }}
    expose:
      - "{{ services.port }}"
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:{{ services.port }}/healthz')"]
      interval: 10s
      timeout: 5s
      retries: 6
      start_period: 20s
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true

  nginx:
    image: {{ nginx.image }}
    restart: {{ services.restart_policy }}
    ports:
      - "{{ nginx.port }}:{{ nginx.port }}"
    networks:
      - {{ network.name }}
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - app_logs:/var/log/nginx
    depends_on:
      service:
        condition: service_healthy
